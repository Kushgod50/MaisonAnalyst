{
  "version": 2,
  "builds": [
    { "src": "api/analyse.js", "use": "@vercel/node" },
    { "src": "api/chat.js", "use": "@vercel/node" },
    { "src": "index.html", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/analyse", "dest": "/api/analyse.js" },
    { "src": "/api/chat", "dest": "/api/chat.js" },
    { "src": "/(.*)", "dest": "/index.html" }
  ],
  "functions": {
    "api/analyse.js": {
      "maxDuration": 300
    },
    "api/chat.js": {
      "maxDuration": 30
    }
  }
}
